def link_content(game_dir: Path):
    game_dir = game_dir.expanduser().resolve()
    exe = game_dir / "Minecraft.Windows.exe"
    if not exe.exists():
        die(f"Minecraft.Windows.exe not found in {game_dir}")
    if CONTENT.is_symlink() or CONTENT.exists():
        if CONTENT.is_symlink():
            CONTENT.unlink()
        else:
            shutil.rmtree(CONTENT)
    CONTENT.symlink_to(game_dir)
    s = load_settings()
    s["game_dir"] = str(game_dir)
    save_settings(s)
    return game_dir


def fix_curl_ssl(game_dir: Path):
    """Replace stub XCurl.dll with real libcurl + CA bundle (online play)."""
    xcurl = game_dir / "XCurl.dll"
    if (game_dir / "XCurl.dll.bol-orig").exists():
        return
    info("Installing real libcurl + CA certificates …")
    pkg = CACHE / "mingw-curl.pkg.tar.zst"
    if not pkg.exists():
        download(MINGW_CURL, pkg, "libcurl")
    extract = CACHE / "mingw-curl"
    extract.mkdir(exist_ok=True)
    try:
        run(["tar", "--use-compress-program=unzstd", "-xf", str(pkg),
             "-C", str(extract)], capture_output=True)
    except Exception:
        run(["tar", "-xf", str(pkg), "-C", str(extract)])
    libcurl = next(extract.rglob("libcurl-4.dll"))
    if xcurl.exists() and not (game_dir / "XCurl.dll.bol-orig").exists():
        shutil.copy2(xcurl, game_dir / "XCurl.dll.bol-orig")
    for nm in ("XCurl.dll", "Xcurl.dll"):
        shutil.copy2(libcurl, game_dir / nm)
    certs = PREFIX / "etc/ssl/certs"
    certs.mkdir(parents=True, exist_ok=True)
    if not (certs / "ca-bundle.crt").exists():
        download(CACERT_URL, certs / "ca-bundle.crt", "CA bundle")
    ok("libcurl + SSL ready")


def proton_env(extra=None):
    root = proton_path()
    env = dict(os.environ)
    env.update({
        "GAMEID": "0",
        "PROTONPATH": str(root),
        "PROTON_VERB": "run",
        "WINEPREFIX": str(PREFIX),
        "STEAM_COMPAT_CLIENT_INSTALL_PATH": str(HOME / ".steam/steam"),
        "UMU_RUNTIME_UPDATE": "0",
    })
    (HOME / ".steam/steam").mkdir(parents=True, exist_ok=True)
    if extra:
        env.update(extra)
    return env


def umu(args, env=None, **kw):
    return run([sys.executable, str(ensure_umu())] + args,
               env=env or proton_env(), **kw)


def setup_prefix(game_dir: Path):
    PREFIX.mkdir(parents=True, exist_ok=True)
    s = load_settings()
    if not s.get("prefix_ready"):
        info("Initialising Wine prefix (first time, please wait) …")
        umu(["wineboot", "--init"], capture_output=True)
        msi = game_dir / "Installers/GameInputRedist.msi"
        if msi.exists():
            info("Installing GameInput redistributable …")
            try:
                umu(["msiexec", "/i", str(msi), "/qn"], capture_output=True)
            except subprocess.CalledProcessError:
                warn("GameInputRedist.msi returned non-zero (often harmless).")
        s["prefix_ready"] = True
        save_settings(s)
        ok("Wine prefix ready")


OPTIONS_REL = ("drive_c/users/steamuser/AppData/Roaming/Minecraft Bedrock/"
               "Users/Shared/games/com.mojang/minecraftpe/options.txt")


def patch_options():
    opt = PREFIX / OPTIONS_REL
    if not opt.exists():
        return
    lines = opt.read_text(errors="ignore").splitlines()
    kv, order = {}, []
    for l in lines:
        if ":" in l:
            k, _, v = l.partition(":")
            k = k.strip()
            if k not in kv:
                order.append(k)
            kv[k] = v.strip()
    if kv.get("do_not_show_multiplayer_online_safety_warning") == "1":
        return
    if "do_not_show_multiplayer_online_safety_warning" not in order:
        order.append("do_not_show_multiplayer_online_safety_warning")
    kv["do_not_show_multiplayer_online_safety_warning"] = "1"
    opt.write_text("\n".join(f"{k}:{kv[k]}" for k in order) + "\n")
    ok("options.txt: multiplayer safety warning disabled")


# --------------------------------------------------------------------------- #
#  ProxyPass background process (with Microsoft device-code surfacing)
# --------------------------------------------------------------------------- #
class ProxyPass:
    def __init__(self):
        self.proc = None
        self.auth = None      # (url, code) when login is required

    def start(self, on_auth=None):
        jar = PROXY_DIR / "ProxyPass.jar"
        log = open(LOGS / "proxypass.log", "w")
        self.proc = subprocess.Popen(
            [str(ensure_jre()), "-jar", str(jar)],
            cwd=str(PROXY_DIR), stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT, text=True, bufsize=1)

        def pump():
            for line in self.proc.stdout:
                log.write(line)
                log.flush()
                m = re.search(r"(https?://\S*microsoft\.com/link\S*)", line, re.I)
                m2 = re.search(r"code\s+([A-Z0-9]{6,9})", line)
                if m or m2:
                    url = (m.group(1) if m else "https://www.microsoft.com/link")
                    code = m2.group(1) if m2 else None
                    self.auth = (url, code)
                    if on_auth:
                        on_auth(url, code)
                    info(c(f"ProxyPass login: open {url} and enter code "
                            f"{code or '(see logs)'}", "y"))
        threading.Thread(target=pump, daemon=True).start()

    def stop(self):
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
            try:
                self.proc.wait(5)
            except subprocess.TimeoutExpired:
                self.proc.kill()


# --------------------------------------------------------------------------- #
#  doctor — verify host has the (very few) required tools
# --------------------------------------------------------------------------- #
def detect_pm():
    for pm, hint in (("apt-get", "sudo apt install {}"),
                     ("dnf", "sudo dnf install {}"),
                     ("pacman", "sudo pacman -S {}"),
                     ("zypper", "sudo zypper install {}")):
        if shutil.which(pm):
            return hint
    return "install with your package manager: {}"


def doctor():
    info(f"{APP} {VERSION} — host check")
    hint = detect_pm()
    pkgs = {"bwrap": "bubblewrap", "tar": "tar", "curl": "curl"}
    missing = []
    print(f"  python3 : {sys.version.split()[0]}")
    for tool, pkg in pkgs.items():
        have = shutil.which(tool)
        print(f"  {tool:8}: {c('found','g') if have else c('MISSING','r')}")
        if not have and not (tool == "curl" and shutil.which("wget")):
            missing.append(pkg)
    if missing:
        warn("Missing tools. Install them with:")
        print("   " + hint.format(" ".join(sorted(set(missing)))))
        return False
    ok("Host is ready.")
    return True


