def java_bin():
    j = JRE_DIR / "bin/java"
    return j if j.exists() else None


def ensure_jre(force=False):
    if java_bin() and not force:
        return java_bin()
    info("Fetching bundled Java 25 (Temurin) …")
    tgz = CACHE / "temurin-jre25.tar.gz"
    download(TEMURIN_JRE25, tgz, "Java 25")
    for x in JRE_DIR.iterdir() if JRE_DIR.exists() else []:
        shutil.rmtree(x, ignore_errors=True) if x.is_dir() else x.unlink()
    JRE_DIR.mkdir(parents=True, exist_ok=True)
    with tarfile.open(tgz) as t:
        members = t.getmembers()
        top = members[0].name.split("/")[0]
        t.extractall(JRE_DIR)
    extracted = JRE_DIR / top
    for item in extracted.iterdir():
        shutil.move(str(item), str(JRE_DIR / item.name))
    extracted.rmdir()
    os.chmod(JRE_DIR / "bin/java", 0o755)
    ok(f"Java 25 → {JRE_DIR/'bin/java'}")
    return JRE_DIR / "bin/java"


