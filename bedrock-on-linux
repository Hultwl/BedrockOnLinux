#  step 4 — ProxyPass build matching the user's Minecraft version
# --------------------------------------------------------------------------- #
def mc_version(game_dir: Path):
    """Derive Bedrock game version 'MAJOR.MINOR.PATCH' from appxmanifest."""
    man = game_dir / "appxmanifest.xml"
    if not man.exists():
        man = game_dir / "AppxManifest.xml"
    if man.exists():
        m = re.search(r'Identity[^>]*Version="(\d+)\.(\d+)\.(\d+)\.(\d+)"',
                      man.read_text(errors="ignore"))
        if m:
            mj, mn, p3 = m.group(1), m.group(2), m.group(3)
            patch = int(p3[:2]) if len(p3) >= 2 else int(p3)
            return f"{mj}.{mn}.{patch}"
    return None


def _ver_tuple(v):
    try:
        return tuple(int(x) for x in v.split("."))
    except Exception:
        return (0,)


def pick_proxypass(game_dir: Path):
    ver = mc_version(game_dir)
    rels = gh_releases(PROXYPASS_REPO, 50)
    pres = []
    for r in rels:
        t = r["tag_name"]
        m = re.match(r"pre/(\d+\.\d+\.\d+)-\d+$", t)
        if m:
            pres.append((m.group(1), r))
    chosen = None
    if ver and pres:
        exact = [r for v, r in pres if v == ver]
        if exact:
            chosen = exact[0]
        else:
            le = sorted([(v, r) for v, r in pres if _ver_tuple(v) <= _ver_tuple(ver)],
                        key=lambda x: _ver_tuple(x[0]))
            if le:
                chosen = le[-1][1]
    if not chosen:
        chosen = next((r for r in rels if r["tag_name"].startswith("master-")), rels[0])
    return chosen, ver


def ensure_proxypass(game_dir: Path, force=False):
    jar = PROXY_DIR / "ProxyPass.jar"
    s = load_settings()
    if jar.exists() and not force and s.get("proxypass_tag"):
        return jar
    rel, ver = pick_proxypass(game_dir)
    url, _ = asset_url(rel, lambda n: n == "ProxyPass.jar")
    if not url:
        die("ProxyPass.jar asset not found.")
    PROXY_DIR.mkdir(parents=True, exist_ok=True)
    download(url, jar, f"ProxyPass {rel['tag_name']}")
    s["proxypass_tag"] = rel["tag_name"]
    s["mc_version"] = ver
    save_settings(s)
    ok(f"ProxyPass {rel['tag_name']} (Minecraft {ver or '?'}) → {jar}")
    return jar


