def cmd_setup(args):
    mkdirs()
    if not doctor():
        die("Fix host requirements first (see above).")
    game = args.game_dir or load_settings().get("game_dir")
    if not game:
        die("Provide your Bedrock GDK folder:  "
            f"{APP} setup --game-dir /path/to/'Minecraft for Windows'")
    game = Path(game).expanduser()
    link_content(game)
    ensure_proton(force=args.force)
    ensure_umu(force=args.force)
    ensure_jre(force=args.force)
    ensure_proxypass(game, force=args.force)
    fix_curl_ssl(game)
    setup_prefix(game)
    s = load_settings()
    s.setdefault("server", {"host": "geo.hivebedrock.network", "port": 19132})
    save_settings(s)
    proxypass_config(s["server"]["host"], s["server"]["port"])
    ok("Setup complete.  Launch with:  " + c(f"{APP} play", "g"))


def cmd_config(args):
    s = load_settings()
    srv = s.setdefault("server", {"host": "geo.hivebedrock.network", "port": 19132})
    if args.server:
        host, _, port = args.server.partition(":")
        srv["host"] = host
        srv["port"] = int(port) if port else 19132
        save_settings(s)
        proxypass_config(srv["host"], srv["port"])
        ok(f"Server set to {srv['host']}:{srv['port']}")
    else:
        print(json.dumps(s, indent=2))


def preflight():
    s = load_settings()
    game = s.get("game_dir")
    if not game or not Path(game, "Minecraft.Windows.exe").exists():
        die(f"Not set up. Run:  {APP} setup --game-dir <folder>")
    if not proton_path():
        die(f"GDK-Proton missing. Run:  {APP} setup")
    return Path(game)


def cmd_play(args):
    game = preflight()
    s = load_settings()
    patch_proton(proton_path())          # idempotent — survives Proton updates
    proxypass_config(s["server"]["host"], s["server"]["port"])

    pp = ProxyPass()
    info("Starting ProxyPass (multiplayer relay) in background …")
    pp.start()

    env = proton_env()
    # We default to X11 (Wine-Wayland proved fragile); pass session through.
    if os.environ.get("DISPLAY"):
        env["DISPLAY"] = os.environ["DISPLAY"]
        env.setdefault("XAUTHORITY", os.environ.get(
            "XAUTHORITY", str(HOME / ".Xauthority")))
    exe = str(CONTENT / "Minecraft.Windows.exe")
    info(c("Launching Minecraft Bedrock …", "g"))
    print(c("  → In game: Play ▸ Friends tab ▸ join the LAN game "
            "(NOT 'Servers'/'Add server', which WineGDK greys out).", "d"))
    glog = open(LOGS / "minecraft.log", "w")
    try:
        subprocess.run([sys.executable, str(ensure_umu()), exe],
                       env=env, cwd=str(CONTENT),
                       stdout=glog, stderr=subprocess.STDOUT)
    finally:
        patch_options()                  # safe now that the game has exited
        pp.stop()
        ok("Game closed; ProxyPass stopped.")


def cmd_doctor(args):
    sys.exit(0 if doctor() else 1)


def cmd_gui(args):
    try:
        import tkinter as tk
        from tkinter import filedialog, messagebox
    except Exception:
        warn("Tkinter not available; falling back to CLI.")
        return cmd_play(args) if load_settings().get("game_dir") else cmd_setup(args)

    s = load_settings()
    root = tk.Tk()
    root.title(f"BedrockOnLinux {VERSION}")
    root.geometry("560x360")
    pad = {"padx": 10, "pady": 6}

    tk.Label(root, text="Minecraft Bedrock — Linux", font=("", 15, "bold")).pack(**pad)

    frm = tk.Frame(root)
    frm.pack(fill="x", **pad)
    tk.Label(frm, text="Bedrock GDK folder:").grid(row=0, column=0, sticky="w")
    gv = tk.StringVar(value=s.get("game_dir", ""))
    tk.Entry(frm, textvariable=gv, width=44).grid(row=0, column=1)

    def browse():
        d = filedialog.askdirectory(title="Folder with Minecraft.Windows.exe")
        if d:
            gv.set(d)
    tk.Button(frm, text="…", command=browse).grid(row=0, column=2)

    tk.Label(frm, text="Server (host:port):").grid(row=1, column=0, sticky="w", pady=4)
    sv = tk.StringVar(value=f"{s.get('server',{}).get('host','geo.hivebedrock.network')}:"
                            f"{s.get('server',{}).get('port',19132)}")
    tk.Entry(frm, textvariable=sv, width=44).grid(row=1, column=1)

    status = tk.StringVar(value="Ready.")
    tk.Label(root, textvariable=status, fg="#555").pack(**pad)
    log = tk.Text(root, height=7, width=64, bg="#111", fg="#3f3")
    log.pack(**pad)

    def logln(m):
        log.insert("end", m + "\n")
        log.see("end")
        root.update()

    def do(action):
        st = load_settings()
        host, _, port = sv.get().partition(":")
        st["server"] = {"host": host, "port": int(port or 19132)}
        if gv.get():
            st["game_dir"] = gv.get()
        save_settings(st)

        def worker():
            try:
                if action == "setup":
                    status.set("Setting up… (downloads, one time)")
                    logln(":: Setup started")
                    a = argparse.Namespace(game_dir=gv.get(), force=False)
                    cmd_setup(a)
                    logln("OK Setup complete")
                    status.set("Setup complete — press Play.")
                else:
                    status.set("Launching… ProxyPass + Minecraft")
                    logln(":: Launching")
                    cmd_play(argparse.Namespace())
            except SystemExit as e:
                logln(f"xx {e}")
                status.set("Error — see log / terminal.")
            except Exception as e:
                logln(f"xx {e}")
                status.set("Error.")
        threading.Thread(target=worker, daemon=True).start()

    bar = tk.Frame(root)
    bar.pack(**pad)
    tk.Button(bar, text="Setup / Update", width=16,
              command=lambda: do("setup")).grid(row=0, column=0, padx=6)
    tk.Button(bar, text="▶ Play", width=16, bg="#2e7d32", fg="white",
              command=lambda: do("play")).grid(row=0, column=1, padx=6)
    root.mainloop()


def main():
    p = argparse.ArgumentParser(
        prog=APP, description="Run Minecraft Bedrock (GDK) on any Linux, "
                              "multiplayer included — everything bundled.")
    sub = p.add_subparsers(dest="cmd")

    sp = sub.add_parser("setup", help="download & prepare everything")
    sp.add_argument("--game-dir", help="folder containing Minecraft.Windows.exe")
    sp.add_argument("--force", action="store_true", help="re-download components")
    sp.set_defaults(func=cmd_setup)

    pl = sub.add_parser("play", help="launch the game + ProxyPass")
    pl.set_defaults(func=cmd_play)

    cf = sub.add_parser("config", help="show/set settings")
    cf.add_argument("--server", help="destination server  host:port")
    cf.set_defaults(func=cmd_config)

    sub.add_parser("doctor", help="check host requirements").set_defaults(func=cmd_doctor)
    sub.add_parser("gui", help="graphical launcher").set_defaults(func=cmd_gui)

    args = p.parse_args()
    if not args.cmd:
        # default: GUI if a display exists, else help
        if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
            return cmd_gui(args)
        p.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        sys.exit(130)
