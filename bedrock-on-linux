# --------------------------------------------------------------------------- #
#  small utilities
# --------------------------------------------------------------------------- #
def c(txt, color):
    if not IS_TTY:
        return txt
    codes = {"g": "32", "y": "33", "r": "31", "b": "34", "c": "36", "d": "2"}
    return f"\033[{codes.get(color,'0')}m{txt}\033[0m"


def info(m): print(f"{c('::','c')} {m}", flush=True)
def ok(m):   print(f"{c('OK','g')} {m}", flush=True)
def warn(m): print(f"{c('!!','y')} {m}", flush=True)
def err(m):  print(f"{c('xx','r')} {m}", file=sys.stderr, flush=True)


def die(m, code=1):
    err(m)
    sys.exit(code)


def run(cmd, **kw):
    kw.setdefault("check", True)
    return subprocess.run(cmd, **kw)


def mkdirs():
    for d in (DATA, PROTON_DIR, UMU_DIR, JRE_DIR, PROXY_DIR, CACHE, LOGS):
