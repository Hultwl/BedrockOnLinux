def umu_run_bin():
    cand = UMU_DIR / "umu-run"
    return cand if cand.exists() else None


def ensure_umu(force=False):
    if umu_run_bin() and not force:
        return umu_run_bin()
    info("Fetching umu-launcher …")
    rel = gh_latest(UMU_REPO)
    url, fname = asset_url(rel, lambda n: n.endswith("zipapp.tar") or n == "umu-run")
    if not url:
        # fall back: any tarball, look for umu-run inside
        url, fname = asset_url(rel, lambda n: n.endswith(".tar") or n.endswith(".tar.gz"))
    if not url:
        die("No umu-launcher asset found.")
    pkg = CACHE / fname
    download(url, pkg, "umu-launcher")
    if fname == "umu-run":
        shutil.copy2(pkg, UMU_DIR / "umu-run")
    else:
        with tarfile.open(pkg) as t:
            t.extractall(UMU_DIR)
        found = next((p for p in UMU_DIR.rglob("umu-run")), None)
        if not found:
            die("umu-run not found in umu-launcher package.")
        if found != UMU_DIR / "umu-run":
            shutil.copy2(found, UMU_DIR / "umu-run")
    os.chmod(UMU_DIR / "umu-run", 0o755)
    ok(f"umu-run → {UMU_DIR/'umu-run'}")
    return UMU_DIR / "umu-run"


