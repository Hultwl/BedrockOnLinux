def load_settings():
    if SETTINGS.exists():
        try:
            return json.loads(SETTINGS.read_text())
        except Exception:
            pass
    return {}


def save_settings(s):
    DATA.mkdir(parents=True, exist_ok=True)
    SETTINGS.write_text(json.dumps(s, indent=2))


def http_json(url):
    req = urllib.request.Request(url, headers={"User-Agent": APP, "Accept": "application/vnd.github+json"})
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read().decode())


def download(url, dest: Path, label=None):
    label = label or dest.name
    dest.parent.mkdir(parents=True, exist_ok=True)
    tmp = dest.with_suffix(dest.suffix + ".part")
    req = urllib.request.Request(url, headers={"User-Agent": APP})
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            total = int(r.headers.get("Content-Length", 0))
            got = 0
            with open(tmp, "wb") as f:
                while True:
                    chunk = r.read(1 << 16)
                    if not chunk:
                        break
                    f.write(chunk)
                    got += len(chunk)
                    if IS_TTY and total:
                        pct = got * 100 // total
                        print(f"\r{c('::','c')} {label}: {pct:3d}%  "
                              f"({got>>20}/{total>>20} MiB)", end="", flush=True)
        if IS_TTY:
            print()
    except urllib.error.URLError as e:
        die(f"Download failed for {url}: {e}")
    tmp.replace(dest)
    return dest


def gh_latest(repo):
    return http_json(f"https://api.github.com/repos/{repo}/releases/latest")


def gh_releases(repo, per_page=40):
    return http_json(f"https://api.github.com/repos/{repo}/releases?per_page={per_page}")


def asset_url(release, predicate):
    for a in release.get("assets", []):
        if predicate(a["name"]):
            return a["browser_download_url"], a["name"]
    return None, None


# --------------------------------------------------------------------------- #
#  minimal PE reader (pure stdlib) — RVA/offset maps + exports (PE32+/x64)
# --------------------------------------------------------------------------- #
class PE:
    def __init__(self, path: Path):
        self.path = Path(path)
        d = self.data = self.path.read_bytes()
        if d[:2] != b"MZ":
            raise ValueError("not a PE")
        e = struct.unpack_from("<I", d, 0x3C)[0]
        if d[e:e + 4] != b"PE\0\0":
            raise ValueError("bad PE signature")
        coff = e + 4
        nsec = struct.unpack_from("<H", d, coff + 2)[0]
        opt = coff + 20
        if struct.unpack_from("<H", d, opt)[0] != 0x20B:
            raise ValueError("not PE32+")
        self.exp_rva = struct.unpack_from("<I", d, opt + 112)[0]
        sect = opt + struct.unpack_from("<H", d, coff + 16)[0]
        self.secs = []
        for i in range(nsec):
            b = sect + i * 40
            vsz, va, rsz, raw = struct.unpack_from("<IIII", d, b + 8)
            self.secs.append((va, vsz, raw, rsz))

    def rva2off(self, rva):
        for va, vsz, raw, rsz in self.secs:
            if va <= rva < va + max(vsz, rsz):
                return raw + (rva - va)
        return None

    def off2rva(self, off):
        for va, vsz, raw, rsz in self.secs:
            if raw <= off < raw + rsz:
                return va + (off - raw)
        return None

    def export_rva(self, name):
        d = self.data
        eo = self.rva2off(self.exp_rva)
        if eo is None:
            return None
        nn = struct.unpack_from("<I", d, eo + 24)[0]
        af = self.rva2off(struct.unpack_from("<I", d, eo + 28)[0])
        an = self.rva2off(struct.unpack_from("<I", d, eo + 32)[0])
        ao = self.rva2off(struct.unpack_from("<I", d, eo + 36)[0])
        t = name.encode()
        for i in range(nn):
            no = self.rva2off(struct.unpack_from("<I", d, an + 4 * i)[0])
            if d[no:d.index(b"\0", no)] == t:
                od = struct.unpack_from("<H", d, ao + 2 * i)[0]
                return struct.unpack_from("<I", d, af + 4 * od)[0]
        return None

    def export_off(self, name):
        r = self.export_rva(name)
        return self.rva2off(r) if r is not None else None


def _backup_once(path: Path):
    bk = path.with_suffix(path.suffix + ".bol-orig")
    if not bk.exists():
        shutil.copy2(path, bk)
    return bk


def apply_patch(path: Path, off: int, expect: bytes, new: bytes, what: str):
    """Idempotent, reversible single patch with a safety check."""
    raw = bytearray(path.read_bytes())
    if bytes(raw[off:off + len(new)]) == new:
        info(f"{what}: already patched")
        return False
    if bytes(raw[off:off + len(expect)]) != expect:
        die(f"{what}: unexpected bytes at 0x{off:x} "
            f"({bytes(raw[off:off+len(expect)]).hex()}) — refusing to patch.")
    _backup_once(path)
    raw[off:off + len(new)] = new
    path.write_bytes(raw)
    ok(f"{what}: patched at 0x{off:x}")
    return True


# --------------------------------------------------------------------------- #
#  step 1 — GDK-Proton (download + the two essential patches)
# --------------------------------------------------------------------------- #
def proton_path():
    s = load_settings()
    p = s.get("proton")
    return Path(p) if p else None


def ensure_proton(force=False):
    s = load_settings()
    cur = proton_path()
    if cur and cur.exists() and not force:
        return cur
    info("Fetching latest GDK-Proton release …")
    rel = gh_latest(GDK_PROTON_REPO)
    tag = rel["tag_name"]
    url, fname = asset_url(rel, lambda n: n.endswith(".tar.gz"))
    if not url:
        die("No GDK-Proton tarball asset found.")
    tar = CACHE / fname
    if not tar.exists():
        download(url, tar, f"GDK-Proton {tag}")
    info("Extracting GDK-Proton (this is ~1.5 GiB) …")
    for d in PROTON_DIR.glob("GDK-Proton*"):
        shutil.rmtree(d, ignore_errors=True)
    with tarfile.open(tar) as t:
        t.extractall(PROTON_DIR)
    root = next(PROTON_DIR.glob("GDK-Proton*"))
    if not (root / "proton").exists():
        die("Extracted GDK-Proton looks wrong (no 'proton' entrypoint).")
    s["proton"] = str(root)
    s["proton_tag"] = tag
    save_settings(s)
    ok(f"GDK-Proton {tag} → {root}")
    patch_proton(root)
    return root


def patch_proton(root: Path):
    """The two fixes that make Minecraft Bedrock GDK 1.26 run under Wine.
    Idempotent and version-robust: locations are found structurally, not
    hardcoded, and the originals are kept as *.bol-orig."""
    wine = root / "files/lib/wine/x86_64-windows"
    combase = wine / "combase.dll"
    ntdll = wine / "ntdll.dll"
    if not combase.exists() or not ntdll.exists():
        die(f"GDK-Proton Wine DLLs not found under {wine}")

    # (1) combase.dll: RoOriginateErrorW is a __wine_stub_ that aborts the
    #     game during the package-identity check. -> `xor eax,eax; ret`.
    off = PE(combase).export_off("RoOriginateErrorW")
    if off is None:
        die("Could not locate RoOriginateErrorW export in combase.dll")
    apply_patch(combase, off,
                bytes.fromhex("4883ec28"),                  # sub $0x28,%rsp
                bytes.fromhex("31c0c3") + b"\x90" * 21,      # xor eax,eax; ret
                "combase.RoOriginateErrorW")

    # (2) ntdll.dll: Wine routes unimplemented imports (NtQueryWnfStateData via
    #     GameInput) through stub funnels that raise EXCEPTION_WINE_STUB and
    #     kill the game ~10 min in. ntdll has SEVERAL identical funnels; we
    #     neutralise every one that provably is such a funnel:
    #       prologue 55 53 48 81 EC C8 00 00 00 48 8D AC 24 C0 00 00 00
    #       + `mov rcx,rbx; call <rel32>` whose target == RtlRaiseException
    #       + immediately followed by `EB F6` (jmp-loop: it never returns)
    #     -> entry becomes `mov eax,0xC0000002 (STATUS_NOT_IMPLEMENTED); ret`.
    pe = PE(ntdll)
    rre = pe.export_rva("RtlRaiseException")
    if rre is None:
        die("Could not resolve RtlRaiseException in ntdll.dll")
    d = pe.data
    sig = bytes.fromhex("55534881ecc8000000488dac24c0000000")
    new = bytes.fromhex("b8020000c0c3") + b"\x90\x90"       # mov eax,..; ret
    funnels, i = [], d.find(sig)
    while i >= 0:
        j = d.find(bytes.fromhex("4889d9e8"), i, i + 0x90)   # mov rcx,rbx; call
        if j >= 0:
            callfo = j + 3                                   # offset of E8
            rel = struct.unpack_from("<i", d, callfo + 1)[0]
            if (pe.off2rva(callfo) + 5 + rel == rre
                    and d[callfo + 5:callfo + 7] == b"\xeb\xf6"):
                funnels.append(i)
        i = d.find(sig, i + 1)

    if funnels:
        raw = bytearray(d)
        for off in funnels:
            raw[off:off + len(new)] = new
        _backup_once(ntdll)
        ntdll.write_bytes(raw)
        ok(f"ntdll: neutralised {len(funnels)} unimplemented-stub funnel(s)")
    else:
        # already patched? our patch leaves bytes [6:] = 90 90 00 48 8D AC ...
        if d.count(new + bytes.fromhex("00488dac24c0000000")) > 0:
            info("ntdll: already patched")
        else:
            die("ntdll: no stub funnel matched — Proton layout changed.")


