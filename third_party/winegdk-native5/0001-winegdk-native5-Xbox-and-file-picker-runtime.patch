+             debugstr_guid( runtime_class_id ), debugstr_guid( interface_id ),
+             status );
+    else if (report_limit)
+        ERR( "unsupported GDK QueryApiImpl log limit reached; suppressing new pairs.\n" );
+
+    return status;
