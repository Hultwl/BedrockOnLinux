VKD3D_DEBIAN_GLSLANG_TOOLS_VERSION='15.1.0+1.4.309.0-1'
VKD3D_DEBIAN_SPIRV_TOOLS_VERSION='2025.1~rc1-1'
VKD3D_DEBIAN_PYTHON3_VERSION='3.13.5-1'
VKD3D_DEBIAN_GIT_VERSION='1:2.47.3-0+deb13u1'
VKD3D_MESON_VERSION='1.7.0'
VKD3D_NINJA_VERSION_PREFIX='1.13.0'
VKD3D_PYTHON_VERSION='Python 3.13.5'
VKD3D_GIT_VERSION='git version 2.47.3'
VKD3D_GLSLANG_VERSION='Glslang Version: 11:15.2.0'
VKD3D_X64_GCC_VERSION='x86_64-w64-mingw32-gcc (GCC) 14-win32'
VKD3D_X86_GCC_VERSION='i686-w64-mingw32-gcc (GCC) 14-win32'
