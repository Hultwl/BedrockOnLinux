VKD3D_OUTPUT_HASHES_SHA256='c64397dec052d7f86f65a0f39d6aecb813d4d1527327fe572cab3e4b59d6ad24'

# GNU PE link timestamps from the reviewed r11 payload. SOURCE_DATE_EPOCH makes
# these explicit inputs instead of depending on the wall clock.
VKD3D_SOURCE_DATE_EPOCH_X64='1783783061'
VKD3D_SOURCE_DATE_EPOCH_X86='1783783103'

# The original relative build layout is part of the binary input because
# vkd3d-proton retains relative __FILE__ strings after stripping.
VKD3D_SOURCE_DIR_NAME='vkd3d-proton-r9'
VKD3D_BUILD_PARENT_NAME='vkd3d-build-output'
VKD3D_OUTPUT_DIR_NAME='vkd3d-proton-3.0.1-nv-dgc'

# Reviewed toolchain. The build script checks these before compiling and checks
# final DLL hashes afterwards, which is the authoritative drift detector.
# Debian package versions are recorded even where the portable preflight below
# can only inspect the executable's own version output.
VKD3D_DEBIAN_GCC_MINGW_VERSION='14.2.0-19+27+b1'
VKD3D_DEBIAN_BINUTILS_MINGW_VERSION='2.44-3+12+b1'
VKD3D_DEBIAN_MINGW_W64_TOOLS_VERSION='12.0.0-5'
VKD3D_DEBIAN_MESON_VERSION='1.7.0-1'
