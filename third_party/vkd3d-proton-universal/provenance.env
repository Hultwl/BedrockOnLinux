# Machine-readable provenance lock for scripts/build-vkd3d-universal.sh.
# Values are deliberately shell-safe literals; this file is sourced by Bash.

VKD3D_UPSTREAM_URL='https://github.com/HansKristian-Work/vkd3d-proton.git'
VKD3D_TAG='v3.0.1'
VKD3D_BASE_COMMIT='3b10bd7a7ec6a7347e616cf8bea59333afec2255'
VKD3D_REMOVAL_COMMIT='76c11d2e2b90b0a46dc894508e67e2aaacc2c04d'
